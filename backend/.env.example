PORT=4000

# Supabase (required)
SUPABASE_URL=https://jhwqsnfbblhgaxvewrrd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-dashboard

# JWT auth
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-this-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Optional message broker (rabbitmq | kafka | leave empty for in-memory)
BROKER=
RABBITMQ_URL=amqp://localhost
KAFKA_BROKERS=localhost:9092

# Frontend allowed origin for CORS (Vercel URL once deployed)
FRONTEND_ORIGIN=*

# Allowed campus email domain for student self-registration (lowercase).
# Default dorsu.edu.ph. Use * for any domain (development only — not recommended production).
REGISTRATION_EMAIL_DOMAIN=dorsu.edu.ph
