PORT=4000

# Supabase (required)
SUPABASE_URL=https://jhwqsnfbblhgaxvewrrd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-dashboard

# JWT auth
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=change-this-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=365d

# Optional message broker (rabbitmq | kafka | leave empty for in-memory)
BROKER=
RABBITMQ_URL=amqp://localhost
KAFKA_BROKERS=localhost:9092

# Frontend allowed origin for CORS (Vercel URL once deployed)
FRONTEND_ORIGIN=*

# Allowed campus email domain for student self-registration (lowercase).
# Default dorsu.edu.ph. Use * for any domain (development only — not recommended production).
REGISTRATION_EMAIL_DOMAIN=dorsu.edu.ph

# Optional Sigla Assistant (Groq). Never commit a real API key — use Render/Vercel env instead.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Spotify (optional — powers /api/music/search, OAuth link, stories sound metadata, profile “Now Playing”)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must exactly match Spotify Developer Dashboard → Redirect URI (backend URL)
SPOTIFY_REDIRECT_URI=http://localhost:4000/api/music/spotify/callback
# Where Spotify sends people after OAuth (SPA). No wildcards — e.g. local Vite or production frontend /music URL
SPOTIFY_FRONTEND_AFTER_LINK=http://localhost:5173/music
